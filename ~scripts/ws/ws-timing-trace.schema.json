{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "WonderSwan Timing Trace Line",
	"description": "Single-line JSON record emitted by ws-timing-trace.lua",
	"type": "object",
	"required": [
		"index",
		"eventId",
		"scanline",
		"data0",
		"data1"
	],
	"properties": {
		"index": {
			"type": "integer",
			"minimum": 0
		},
		"eventId": {
			"type": "integer",
			"minimum": 0,
			"maximum": 255
		},
		"scanline": {
			"type": "integer",
			"minimum": 0,
			"maximum": 255
		},
		"data0": {
			"type": "integer",
			"minimum": 0,
			"maximum": 255
		},
		"data1": {
			"type": "integer",
			"minimum": 0,
			"maximum": 255
		}
	}
}
