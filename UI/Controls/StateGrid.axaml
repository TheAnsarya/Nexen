<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:c="using:Nexen.Controls"
	xmlns:cfg="using:Nexen.Config"
	xmlns:l="using:Nexen.Localization"
	mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
  Background="Transparent"
	Name="root"
	x:DataType="c:StateGrid"
	x:Class="Nexen.Controls.StateGrid"
>
	<UserControl.Resources>
		<Color x:Key="ButtonBackgroundPointerOver">#2A2A2A</Color>
		<Color x:Key="ButtonBackgroundPressed">Transparent</Color>
	</UserControl.Resources>

	<DockPanel DataContext="{Binding ElementName=root}">
		<Panel DockPanel.Dock="Top" Margin="5" IsVisible="{Binding Title.Length}">
			<TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Medium" Foreground="White" TextAlignment="Center" />
			<Button IsVisible="{Binding ShowClose}" Click="OnCloseClick" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Padding="0" Margin="0 -2 0 -2" MinWidth="0">
				<Image Source="/Assets/CloseWhite.png" Width="16" Height="16" />
			</Button>
		</Panel>
		<!-- Action buttons row — visible only in RecentGames mode -->
		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 6 0 8" Spacing="24" IsVisible="{Binding ShowActionButtons}">
			<Button Click="OnOpenRomClick" Background="#2A2A2A" BorderBrush="SlateGray" BorderThickness="1" CornerRadius="6" Padding="16 8" Cursor="Hand">
				<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<Image Source="{SvgImage /Assets/Folder.svg}" Width="24" Height="24" />
					<TextBlock Text="Open ROM" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
				</StackPanel>
			</Button>
			<Button Click="OnVerifiedGamesClick" Background="#2A2A2A" BorderBrush="SlateGray" BorderThickness="1" CornerRadius="6" Padding="16 8" Cursor="Hand" IsEnabled="False" Opacity="0.5">
				<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<Image Source="{SvgImage /Assets/Find.svg}" Width="24" Height="24" />
					<TextBlock Text="Verified Games" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
				</StackPanel>
			</Button>
		</StackPanel>
		<Button DockPanel.Dock="Left" IsVisible="{Binding ShowArrows}" Background="Transparent" BorderThickness="0" Click="OnPrevPageClick" VerticalAlignment="Stretch" Height="NaN" MinWidth="0" Margin="0">
			<Image Source="{SvgImage /Assets/MediaPlay.svg}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="16">
				<Image.RenderTransform>
					<RotateTransform Angle="180" />
				</Image.RenderTransform>
			</Image>
		</Button>
		<Button DockPanel.Dock="Right" IsVisible="{Binding ShowArrows}" Background="Transparent" BorderThickness="0" Click="OnNextPageClick" VerticalAlignment="Stretch" Height="NaN" MinWidth="0" Margin="0">
			<Image Source="{SvgImage /Assets/MediaPlay.svg}" VerticalAlignment="Center" HorizontalAlignment="Right" Width="16" />
		</Button>
		<Grid Name="Grid" />
	</DockPanel>
</UserControl>
