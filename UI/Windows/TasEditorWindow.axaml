<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Nexen"
	xmlns:c="using:Nexen.Controls"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:l="using:Nexen.Localization"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
	x:Class="Nexen.Windows.TasEditorWindow"
	Width="1000" Height="700"
	MinWidth="700" MinHeight="500"
	x:DataType="vm:TasEditorViewModel"
	Title="{Binding WindowTitle}"
>
	<Design.DataContext>
		<vm:TasEditorViewModel />
	</Design.DataContext>

	<DockPanel>
		<!-- Menu Bar -->
		<c:NexenMenu DockPanel.Dock="Top" Name="ActionMenu">
			<MenuItem Header="File" ItemsSource="{Binding FileMenuItems}" />
			<MenuItem Header="Edit" ItemsSource="{Binding EditMenuItems}" />
			<MenuItem Header="View" ItemsSource="{Binding ViewMenuItems}" />
			<MenuItem Header="Playback" ItemsSource="{Binding PlaybackMenuItems}" />
			<MenuItem Header="Recording" ItemsSource="{Binding RecordingMenuItems}" />
			<MenuItem Header="Script" ItemsSource="{Binding ScriptMenuItems}" />
		</c:NexenMenu>

		<!-- Toolbar -->
		<Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0 0 0 1" Padding="5">
			<StackPanel Orientation="Horizontal" Spacing="5">
				<Button Content="Open" ToolTip.Tip="Open movie file" Click="OnOpenClick" />
				<Button Content="Save" ToolTip.Tip="Save movie file" IsEnabled="{Binding HasUnsavedChanges}" Click="OnSaveClick" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<Button Content="↶" ToolTip.Tip="Undo (Ctrl+Z)" Width="30" IsEnabled="{Binding CanUndo}" Click="OnUndoClick" />
				<Button Content="↷" ToolTip.Tip="Redo (Ctrl+Y)" Width="30" IsEnabled="{Binding CanRedo}" Click="OnRedoClick" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<Button Content="+" ToolTip.Tip="Insert frame (Insert)" Width="30" Click="OnInsertFrameClick" />
				<Button Content="-" ToolTip.Tip="Delete frame (Delete)" Width="30" Click="OnDeleteFrameClick" />
				<Button Content="All" ToolTip.Tip="Select all frames (Ctrl+A)" Width="40" Click="OnSelectAllFramesClick" />
				<Button Content="None" ToolTip.Tip="Clear selection (Ctrl+Shift+A)" Width="50" Click="OnSelectNoFramesClick" />
				<Button Content="Range" ToolTip.Tip="Select frame range" Width="55" Click="OnSelectRangeDialogClick" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<Button Content="⏮" ToolTip.Tip="Frame rewind (R)" Width="30" Click="OnFrameRewindClick" />
				<Button Content="⏯" ToolTip.Tip="Play/Pause (Space)" Width="30" Click="OnPlayPauseClick" />
				<Button Content="⏭" ToolTip.Tip="Frame advance (F)" Width="30" Click="OnFrameAdvanceClick" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<ToggleButton Content="●" ToolTip.Tip="Record" Width="30" Foreground="Red" IsChecked="{Binding IsRecording}" Click="OnRecordToggleClick" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<TextBlock Text="Speed:" VerticalAlignment="Center" />
				<TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:F2}x}" VerticalAlignment="Center" Width="40" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<ToggleButton Content="GZ" ToolTip.Tip="Toggle greenzone" IsChecked="{Binding IsGreenzoneEnabled}" />
				<TextBlock Text="{Binding SavestateCount, StringFormat=({0})}" VerticalAlignment="Center" Margin="5 0 0 0" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<TextBlock Text="{Binding GreenzoneMemoryMB, StringFormat={}{0:F1} MB}" VerticalAlignment="Center" />
				<Rectangle Width="1" Fill="Gray" Margin="5 0" />
				<TextBlock Text="📜" ToolTip.Tip="Script running" VerticalAlignment="Center" IsVisible="{Binding IsScriptRunning}" Foreground="Green" />
				<TextBlock Text="{Binding CurrentScriptPath}" ToolTip.Tip="Current script" VerticalAlignment="Center" Margin="5 0 0 0" IsVisible="{Binding IsScriptRunning}" MaxWidth="150" TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</Border>

		<!-- Status Bar -->
		<Border DockPanel.Dock="Bottom" BorderBrush="Gray" BorderThickness="0 1 0 0" Padding="5">
			<Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">
				<TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" />
				<TextBlock Grid.Column="1" Text="Frame: " VerticalAlignment="Center" Margin="10 0 0 0" />
				<TextBlock Grid.Column="2" Text="{Binding SelectedFrameIndex}" VerticalAlignment="Center" />
				<TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="10 0 0 0">
					<TextBlock.Text>
						<MultiBinding StringFormat="/ {0}">
							<Binding Path="Movie.InputFrames.Count" FallbackValue="0" />
						</MultiBinding>
					</TextBlock.Text>
				</TextBlock>
				<TextBlock Grid.Column="4" Text="Rerecords: " VerticalAlignment="Center" Margin="15 0 0 0" />
				<TextBlock Grid.Column="5" Text="{Binding RerecordCount}" VerticalAlignment="Center" />
				<TextBlock Grid.Column="6" Text="{Binding RecordMode, StringFormat=[{0}]}" VerticalAlignment="Center" Margin="10 0 0 0" Foreground="Gray" />
			</Grid>
		</Border>

		<!-- Search Bar (toggle with Ctrl+F) -->
		<Border DockPanel.Dock="Top" IsVisible="{Binding IsSearchVisible}" BorderBrush="Gray" BorderThickness="0 0 0 1" Padding="5" Background="#1a1a2e">
			<StackPanel Orientation="Horizontal" Spacing="5">
				<TextBlock Text="Find:" VerticalAlignment="Center" />
				<TextBox Name="SearchBox" Text="{Binding SearchText}" Width="200" Watermark="Search frames..." />
				<ComboBox SelectedItem="{Binding SearchMode}" ItemsSource="{Binding Source={x:Static vm:TasEditorViewModel.SearchModes}}" Width="120" />
				<Button Content="🔍" ToolTip.Tip="Search (Enter)" Width="30" Click="OnSearchClick" />
				<Button Content="▼" ToolTip.Tip="Next (F3)" Width="30" Click="OnSearchNextClick" />
				<Button Content="▲" ToolTip.Tip="Previous (Shift+F3)" Width="30" Click="OnSearchPreviousClick" />
				<TextBlock Text="{Binding SearchSummary}" VerticalAlignment="Center" Margin="10 0 0 0" Foreground="Cyan" />
				<Button Content="✕" ToolTip.Tip="Close search" Width="30" Click="OnSearchCloseClick" HorizontalAlignment="Right" />
			</StackPanel>
		</Border>

		<!-- Main Content -->
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="{Binding ShowPianoRoll, Converter={x:Static c:BoolToGridLengthConverter.Instance}}" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="5" />
				<ColumnDefinition Width="250" />
			</Grid.ColumnDefinitions>

			<!-- Frame List (ListBox) -->
			<Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
				<ListBox
					Name="FrameList"
					ItemsSource="{Binding Frames}"
					SelectedIndex="{Binding SelectedFrameIndex}"
					SelectionMode="Multiple"
					FontFamily="Consolas"
					FontSize="12"
				>
					<ListBox.ContextMenu>
						<ContextMenu>
							<MenuItem Header="Insert Frame _Above" Click="OnInsertAboveClick" />
							<MenuItem Header="Insert Frame _Below" Click="OnInsertBelowClick" />
							<Separator />
							<MenuItem Header="Cu_t" Click="OnCutClick" InputGesture="Ctrl+X" />
							<MenuItem Header="_Copy" Click="OnCopyClick" InputGesture="Ctrl+C" />
							<MenuItem Header="_Paste" Click="OnPasteClick" InputGesture="Ctrl+V" />
							<Separator />
							<MenuItem Header="_Delete Selected" Click="OnDeleteClick" InputGesture="Delete" />
							<MenuItem Header="C_lear Input" Click="OnClearInputClick" />
							<Separator />
							<MenuItem Header="Select _All" Click="OnSelectAllClick" InputGesture="Ctrl+A" />
							<MenuItem Header="Select _None" Click="OnSelectNoneClick" InputGesture="Ctrl+Shift+A" />
							<MenuItem Header="Select _Range..." Click="OnSelectRangeDialogFromMenuClick" />
							<MenuItem Header="Select Range _To Here" Click="OnSelectRangeToHereClick" />
							<Separator />
							<MenuItem Header="_Insert N Frames..." Click="OnBulkInsertClick" />
							<MenuItem Header="Bulk _Set Button..." Click="OnBulkSetButtonClick" />
							<MenuItem Header="Bulk C_lear Button..." Click="OnBulkClearButtonClick" />
							<MenuItem Header="_Pattern Fill..." Click="OnPatternFillClick" />
							<Separator />
							<MenuItem Header="Set _Comment..." Click="OnSetCommentClick" />
							<MenuItem Header="Set _Marker" Click="OnSetMarkerClick" />
						</ContextMenu>
					</ListBox.ContextMenu>
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="16,16,60,120,120,40,*" Background="{Binding Background}">
								<!-- Greenzone indicator -->
								<Ellipse Grid.Column="0" Width="8" Height="8" Fill="LimeGreen"
									IsVisible="{Binding IsGreenzone}" HorizontalAlignment="Center" VerticalAlignment="Center" />
								<!-- Marker indicator -->
								<TextBlock Grid.Column="1" Text="📌" FontSize="10"
									IsVisible="{Binding HasMarker}" HorizontalAlignment="Center" VerticalAlignment="Center" />
								<TextBlock Grid.Column="2" Text="{Binding FrameNumber}" />
								<TextBlock Grid.Column="3" Text="{Binding P1Input}" />
								<TextBlock Grid.Column="4" Text="{Binding P2Input}" />
								<TextBlock Grid.Column="5" Text="L" FontWeight="Bold" Foreground="Red"
									IsVisible="{Binding IsLagFrame}" HorizontalAlignment="Center" />
								<TextBlock Grid.Column="6" Text="{Binding CommentText}" Foreground="Gray" />
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Border>

			<!-- Splitter -->
			<GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns" />

			<!-- Properties Panel -->
			<Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1">
				<ScrollViewer>
					<StackPanel Margin="10" Spacing="10">
						<!-- Frame Info -->
						<TextBlock Text="Frame Properties" FontWeight="Bold" FontSize="14" />
						<Rectangle Height="1" Fill="Gray" />

						<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
							<TextBlock Text="Frame #:" VerticalAlignment="Center" />
							<TextBlock Grid.Column="1" Text="{Binding SelectedFrameIndex}" Margin="5 0 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="1" Text="Lag Frame:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding SelectedFrameIsLag}" Margin="5 5 0 0" IsEnabled="False" />
						</Grid>

						<!-- Controller Layout -->
						<TextBlock Text="Controller Layout" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />

						<ComboBox
							ItemsSource="{Binding AvailableLayouts}"
							SelectedItem="{Binding CurrentLayout}"
							HorizontalAlignment="Stretch"
						/>

					<!-- Port Selector (visible when multiple ports) -->
					<StackPanel IsVisible="{Binding IsPortSelectorVisible}" Spacing="4">
						<TextBlock Text="Active Port" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />
						<c:NexenNumericUpDown Value="{Binding SelectedEditPort}" Minimum="0" Maximum="{Binding MaxEditPort}" Width="80" />
					</StackPanel>

					<!-- Controller Buttons -->
					<TextBlock Text="Controller Buttons" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />

						<ItemsControl ItemsSource="{Binding ControllerButtons}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Button
										Content="{Binding Label}"
										Tag="{Binding ButtonId}"
										Width="40"
										Height="30"
										Margin="2"
										Click="OnButtonClick"
									/>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<StackPanel IsVisible="{Binding IsPaddleCoordinateEditorVisible}" Spacing="6">
							<TextBlock Text="Paddle Position" FontWeight="SemiBold" Margin="0 4 0 0" />
							<StackPanel Orientation="Horizontal" Spacing="6">
								<c:NexenNumericUpDown Value="{Binding SelectedPaddlePosition}" Minimum="0" Maximum="255" Width="100" />
								<TextBlock Text="(0-255)" VerticalAlignment="Center" Foreground="Gray" />
							</StackPanel>
						</StackPanel>

						<!-- Console Switches (Atari 2600 only) -->
						<StackPanel IsVisible="{Binding IsConsoleSwitchPanelVisible}" Spacing="4">
							<TextBlock Text="Console Switches" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
							<Rectangle Height="1" Fill="Gray" />
							<StackPanel Orientation="Horizontal" Spacing="6">
								<ToggleButton
									Content="SELECT"
									IsChecked="{Binding IsSelectedFrameSelectActive}"
									Click="OnConsoleSwitchSelectClick"
									Width="70" Height="28"
									ToolTip.Tip="Toggle Atari 2600 Select switch on selected frame(s)"
								/>
								<ToggleButton
									Content="RESET"
									IsChecked="{Binding IsSelectedFrameResetActive}"
									Click="OnConsoleSwitchResetClick"
									Width="70" Height="28"
									Foreground="OrangeRed"
									ToolTip.Tip="Toggle Atari 2600 Reset switch on selected frame(s)"
								/>
							</StackPanel>
						</StackPanel>

						<!-- Input preview pane -->
						<TextBlock Text="Input Preview" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />

						<TextBlock Text="Raw Hex (all ports)" FontWeight="SemiBold" />
						<TextBox
							Text="{Binding SelectedFrameHexPreview}"
							IsReadOnly="True"
							AcceptsReturn="True"
							TextWrapping="Wrap"
							Height="68"
							FontFamily="Consolas"
							FontSize="12"
						/>

						<TextBlock Text="Controller Diagram (P1)" FontWeight="SemiBold" Margin="0 4 0 0" />
						<ItemsControl ItemsSource="{Binding InputPreviewButtons}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Columns="{Binding InputPreviewColumns}" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Background="{Binding Background}" CornerRadius="4" Padding="4" Margin="2" MinWidth="36">
										<TextBlock Text="{Binding Label}" Foreground="{Binding Foreground}" FontWeight="Bold" HorizontalAlignment="Center" />
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- Movie Info -->
						<TextBlock Text="Movie Info" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />

						<Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
							<TextBlock Text="Format:" VerticalAlignment="Center" />
							<TextBlock Grid.Column="1" Text="{Binding Movie.SourceFormat, FallbackValue=None}" Margin="5 0 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="1" Text="Layout:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentLayout}" Margin="5 5 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="2" Text="Frames:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Movie.TotalFrames, FallbackValue=0}" Margin="5 5 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="3" Text="Rerecords:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Movie.RerecordCount, FallbackValue=0}" Margin="5 5 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="4" Text="Author:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Movie.Author, FallbackValue=Unknown}" Margin="5 5 0 0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

							<TextBlock Grid.Row="5" Text="Game:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Movie.GameName, FallbackValue=—}" Margin="5 5 0 0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

							<TextBlock Grid.Row="6" Text="System:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Movie.SystemType, FallbackValue=—}" Margin="5 5 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="7" Text="Region:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Movie.Region, FallbackValue=—}" Margin="5 5 0 0" VerticalAlignment="Center" />

							<TextBlock Grid.Row="8" Text="ROM:" VerticalAlignment="Center" Margin="0 5 0 0" />
							<TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Movie.RomFileName, FallbackValue=—}" Margin="5 5 0 0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Movie.RomFileName}" />
						</Grid>

						<!-- Auto-save settings -->
						<TextBlock Text="Auto-Save" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />
						<StackPanel Orientation="Horizontal" Margin="0 0 0 5">
							<CheckBox Content="Enable auto-save" IsChecked="{Binding AutoSaveEnabled}" />
						</StackPanel>
						<StackPanel Orientation="Horizontal" Margin="0 0 0 5">
							<TextBlock Text="Interval (minutes):" VerticalAlignment="Center" />
							<c:NexenNumericUpDown Value="{Binding AutoSaveIntervalMinutes}" Margin="6 0 0 0" Minimum="1" Maximum="60" Width="70" IsEnabled="{Binding AutoSaveEnabled}" />
						</StackPanel>

						<!-- Marker/comment list panel -->
						<TextBlock Text="Markers &amp; Comments" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />
						<StackPanel Orientation="Horizontal" Margin="0 0 0 5" Spacing="6">
							<TextBlock Text="Filter:" VerticalAlignment="Center" />
							<ComboBox Width="130" ItemsSource="{Binding MarkerEntryFilters}" SelectedItem="{Binding MarkerEntryFilter}" />
						</StackPanel>
						<ListBox
							Name="MarkerList"
							ItemsSource="{Binding MarkerEntries}"
							SelectedItem="{Binding SelectedMarkerEntry}"
							MaxHeight="150"
							SelectionMode="Single"
							DoubleTapped="OnMarkerEntryDoubleTapped"
						>
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Grid ColumnDefinitions="65,70,*" Margin="0 1">
										<TextBlock Grid.Column="0" Text="{Binding FrameIndex, StringFormat=F#{0}}" />
										<TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="Gray" />
										<TextBlock Grid.Column="2" Text="{Binding Comment}" TextTrimming="CharacterEllipsis" />
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
						<WrapPanel Margin="0 5 0 0" Orientation="Horizontal" ItemHeight="28" ItemWidth="70">
							<Button Content="Add" Click="OnMarkerAddClick" />
							<Button Content="Edit" Click="OnMarkerEditClick" />
							<Button Content="Delete" Click="OnMarkerDeleteClick" />
							<Button Content="Export" Click="OnMarkerExportClick" />
						</WrapPanel>

						<!-- Branches -->
						<TextBlock Text="Branches" FontWeight="Bold" FontSize="14" Margin="0 10 0 0" />
						<Rectangle Height="1" Fill="Gray" />

						<ListBox
							ItemsSource="{Binding Branches}"
							MaxHeight="100"
							SelectionMode="Single"
						>
							<ListBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="{Binding Name}" />
										<TextBlock Text="{Binding FrameCount, StringFormat=' ({0} frames)'}" Foreground="Gray" />
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>
				</ScrollViewer>
			</Border>

			<!-- Piano Roll Splitter -->
			<GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
				Height="5" ResizeDirection="Rows" IsVisible="{Binding ShowPianoRoll}" />

			<!-- Piano Roll Panel -->
			<Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
				BorderBrush="Gray" BorderThickness="1" IsVisible="{Binding ShowPianoRoll}">
				<c:PianoRollControl
					Name="PianoRoll"
					Frames="{Binding Movie.InputFrames}"
					SelectedFrame="{Binding SelectedFrameIndex}"
					PlaybackFrame="{Binding PlaybackFrame}"
					GreenzoneStart="{Binding GreenzoneStart}"
					ButtonLabels="{Binding PianoRollButtonLabels}"
					Height="200"
				/>
			</Border>
		</Grid>
	</DockPanel>
</Window>
