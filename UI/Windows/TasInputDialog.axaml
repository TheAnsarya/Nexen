<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	d:DesignWidth="400"
	d:DesignHeight="200"
	x:Class="Nexen.Windows.TasInputDialog"
	SizeToContent="Height"
	Width="350"
	CanResize="False"
	Focusable="True"
	WindowStartupLocation="CenterOwner"
	Title="Input"
	Background="{StaticResource NexenDarkBackgroundColor}"
>
	<StackPanel Margin="20" Spacing="10">
		<TextBlock
			Name="txtPrompt"
			Text="Enter value:"
			FontSize="14"
			Foreground="LightGray"
		/>

		<TextBox
			Name="txtInput"
			FontSize="14"
			Watermark="Enter value..."
		/>

		<TextBlock
			Name="txtError"
			Text=""
			FontSize="11"
			Foreground="Red"
			IsVisible="False"
		/>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
			<Button Content="OK" Width="80" Click="OnOkClick" Name="btnOk" IsDefault="True" />
			<Button Content="Cancel" Width="80" Click="OnCancelClick" IsCancel="True" />
		</StackPanel>
	</StackPanel>
</Window>
