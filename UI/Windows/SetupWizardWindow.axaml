<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Nexen"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:l="using:Nexen.Localization"
	xmlns:v="using:Nexen.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Nexen.Windows.SetupWizardWindow"
	Width="980" Height="860"
	MinWidth="860" MinHeight="720"
	WindowDecorations="None"
	CanResize="True"
	WindowStartupLocation="CenterScreen"
	x:DataType="vm:SetupWizardViewModel"
	Title="{l:Translate wndTitle}"
	Name="root"
	Background="#ff1d130d"
	Foreground="#ffffffff"
>
	<Design.DataContext>
		<vm:SetupWizardViewModel />
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="RadioButton.choiceCard">
			<Setter Property="Foreground" Value="#ffe1852c" />
			<Setter Property="Background" Value="#ff2a1a10" />
			<Setter Property="BorderBrush" Value="#ffbf5e12" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="Template">
				<ControlTemplate>
					<Grid MinHeight="74" Cursor="Hand">
						<Border x:Name="Card"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="14"
						/>
						<Border x:Name="LeftEdge"
							Width="14"
							Background="#22000000"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="2,2,0,2"
							HorizontalAlignment="Left"
							VerticalAlignment="Stretch"
							Margin="-8,6,0,6"
						>
							<Border.RenderTransform>
								<SkewTransform AngleX="-22" />
							</Border.RenderTransform>
						</Border>
						<Border x:Name="RightEdge"
							Width="14"
							Background="#22000000"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="0,2,2,2"
							HorizontalAlignment="Right"
							VerticalAlignment="Stretch"
							Margin="0,6,-8,6"
						>
							<Border.RenderTransform>
								<SkewTransform AngleX="24" />
							</Border.RenderTransform>
						</Border>
						<ContentPresenter Margin="18,12" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
					</Grid>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ Border#Card">
			<Setter Property="Background" Value="#ff4a2d1a" />
			<Setter Property="BorderBrush" Value="#ffe8a34c" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ ContentPresenter TextBlock">
			<Setter Property="Foreground" Value="#ffffb45c" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ Border#LeftEdge">
			<Setter Property="Background" Value="#ffffa93d" />
			<Setter Property="BorderBrush" Value="#ffffa93d" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ Border#RightEdge">
			<Setter Property="Background" Value="#ffffa93d" />
			<Setter Property="BorderBrush" Value="#ffffa93d" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ Border#Card">
			<Setter Property="Background" Value="#ffbf5e12" />
			<Setter Property="BorderBrush" Value="#ffe7a24a" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ Border#LeftEdge">
			<Setter Property="Background" Value="#ffffbe66" />
			<Setter Property="BorderBrush" Value="#ffffbe66" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ Border#RightEdge">
			<Setter Property="Background" Value="#ffffbe66" />
			<Setter Property="BorderBrush" Value="#ffffbe66" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ ContentPresenter TextBlock">
			<Setter Property="Foreground" Value="#ffffffff" />
		</Style>

		<Style Selector="TextBlock.cardTitle">
			<Setter Property="Foreground" Value="#ffffffff" />
			<Setter Property="FontSize" Value="20" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style Selector="TextBlock.cardHint">
			<Setter Property="Foreground" Value="#ffefcfb6" />
			<Setter Property="FontSize" Value="14" />
		</Style>
	</Window.Styles>

	<Border BorderThickness="2" BorderBrush="#ff6b3f24" Background="#ff1d130d">
		<Grid Margin="22" RowDefinitions="Auto,*,Auto">
			<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
				<StackPanel Spacing="4">
					<TextBlock Text="Nexen" FontSize="14" Foreground="#ffefcfb6" />
					<TextBlock Text="First Start Options" FontSize="34" FontWeight="Bold" />
					<TextBlock Text="Pick what you need now. You can change everything later." Foreground="#ffefcfb6" />
				</StackPanel>
				<Image
					Grid.Column="1"
					Source="/Assets/NexenIcon.ico"
					Height="52"
					Width="52"
					VerticalAlignment="Top"
				/>
				<Border Grid.Row="1" Grid.ColumnSpan="2" IsVisible="{Binding HasResumedDraft}" Background="#ff3b2416" BorderBrush="#ffbf5e12" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,14,0,0">
					<DockPanel LastChildFill="False">
						<TextBlock DockPanel.Dock="Left" Width="700" Text="Saved setup found. Continue or start over." TextWrapping="Wrap" Foreground="#ffffffff" FontSize="16" />
						<Button DockPanel.Dock="Right" Background="#ffe1852c" Foreground="White" FontWeight="SemiBold" Padding="18,8" MinHeight="40" Click="StartFresh_OnClick" Content="Start Fresh" />
					</DockPanel>
				</Border>
			</Grid>

			<ScrollViewer Grid.Row="1" Margin="0,20,0,20" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<Border Background="#ff2a1a10" BorderBrush="#ff6b3f24" BorderThickness="1" CornerRadius="12" Padding="16">
					<StackPanel Spacing="14">
						<TextBlock FontSize="20" FontWeight="SemiBold" Text="How will you use Nexen?" />
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="PrimaryUsage" IsChecked="{Binding UsePlayingProfile}">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" Text="Play Games" />
									<TextBlock Classes="cardHint" Text="Good defaults for normal play." />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="PrimaryUsage" IsChecked="{Binding UseDebuggingProfile}" Grid.Column="1">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" Text="Hacking" />
									<TextBlock Classes="cardHint" Text="More tools and debug defaults." />
								</StackPanel>
							</RadioButton>
						</Grid>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<Grid ColumnDefinitions="*,Auto">
							<TextBlock FontSize="20" FontWeight="SemiBold" Text="Where should Nexen save your data?" />
							<Button Grid.Column="1" HorizontalAlignment="Right" Background="#ffbf5e12" Foreground="White" FontWeight="SemiBold" Padding="12,6" MinHeight="34" Click="ResetStorageToRecommended_OnClick" Content="↻ Reset" />
						</Grid>
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="Storage" IsChecked="{Binding StoreInUserProfile}">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Use Documents (Recommended)" TextWrapping="Wrap" />
									<TextBlock Classes="cardHint" Text="Best for most users." />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="Storage" IsChecked="{Binding UsePortableMode}" Grid.Column="1" IsEnabled="{Binding CanUsePortableMode}">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Use Current Folder" />
									<TextBlock Classes="cardHint" Text="Keep data next to Nexen." />
								</StackPanel>
							</RadioButton>
						</Grid>
						<TextBlock IsVisible="{Binding !CanUsePortableMode}" Foreground="#ffe1852c" Text="Portable mode is unavailable in AppImage environments." />
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Selected path:" Foreground="#ffefcfb6" FontSize="19" FontWeight="SemiBold" />
							<TextBlock Text="{Binding InstallLocation}" FontSize="19" FontWeight="SemiBold" Foreground="#ffffffff" />
						</StackPanel>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<TextBlock FontSize="20" FontWeight="SemiBold" Text="Configure input" />
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="InputSetup" IsChecked="{Binding ConfigureInputMappingsNow}">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Configure Now" />
									<TextBlock Classes="cardHint" Text="Pick prompt and keyboard style." />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="InputSetup" IsChecked="{Binding UseInputDefaultsNow}" Grid.Column="1">
								<StackPanel Spacing="4">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Use Defaults" />
									<TextBlock Classes="cardHint" Text="Quick start input setup." />
								</StackPanel>
							</RadioButton>
						</Grid>

						<StackPanel IsVisible="{Binding ConfigureInputMappingsNow}" Spacing="10" Margin="0,2,0,0">
							<TextBlock FontSize="18" FontWeight="SemiBold" Text="Prompt Style" />
							<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
								<RadioButton Classes="choiceCard" GroupName="ControllerStyle" IsChecked="{Binding UseXboxPromptStyle}">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Xbox" />
								</RadioButton>
								<RadioButton Classes="choiceCard" GroupName="ControllerStyle" IsChecked="{Binding UsePlayStationPromptStyle}" Grid.Column="1">
									<TextBlock Classes="cardTitle" FontSize="18" Text="PlayStation" />
								</RadioButton>
							</Grid>

							<TextBlock FontSize="18" FontWeight="SemiBold" Text="Keyboard" />
							<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
								<RadioButton Classes="choiceCard" GroupName="KeyboardStyle" IsChecked="{Binding EnableWasdMappings}">
									<TextBlock Classes="cardTitle" FontSize="18" Text="WASD" />
								</RadioButton>
								<RadioButton Classes="choiceCard" GroupName="KeyboardStyle" IsChecked="{Binding EnableArrowMappings}" Grid.Column="1">
									<TextBlock Classes="cardTitle" FontSize="18" Text="Arrow Keys" />
								</RadioButton>
							</Grid>
						</StackPanel>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<Grid ColumnDefinitions="2*,*,*" ColumnSpacing="12" IsVisible="{Binding !IsOsx}">
							<TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Desktop Shortcut" />
							<RadioButton Grid.Column="1" Classes="choiceCard" GroupName="Shortcut" IsChecked="{Binding CreateShortcutYes}" MinHeight="60">
								<TextBlock Classes="cardTitle" FontSize="18" Text="Yes" />
							</RadioButton>
							<RadioButton Grid.Column="2" Classes="choiceCard" GroupName="Shortcut" IsChecked="{Binding CreateShortcutNo}" MinHeight="60">
								<TextBlock Classes="cardTitle" FontSize="18" Text="No" />
							</RadioButton>
						</Grid>

						<Grid ColumnDefinitions="2*,*,*" ColumnSpacing="12">
							<TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Auto Update" />
							<RadioButton Grid.Column="1" Classes="choiceCard" GroupName="Updates" IsChecked="{Binding CheckForUpdatesYes}" MinHeight="60">
								<TextBlock Classes="cardTitle" FontSize="18" Text="Yes" />
							</RadioButton>
							<RadioButton Grid.Column="2" Classes="choiceCard" GroupName="Updates" IsChecked="{Binding CheckForUpdatesNo}" MinHeight="60">
								<TextBlock Classes="cardTitle" FontSize="18" Text="No" />
							</RadioButton>
						</Grid>
					</StackPanel>
				</Border>
			</ScrollViewer>

			<Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
				<Button Background="#ffe1852c" Foreground="White" FontWeight="SemiBold" Padding="24,12" MinHeight="46" Content="Cancel" Click="Cancel_OnClick" />
				<TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Setup takes less than a minute." Foreground="#ffefcfb6" />
				<Button Grid.Column="2" Background="#ffe1852c" Foreground="White" FontWeight="SemiBold" Padding="24,12" MinHeight="46" HorizontalAlignment="Right" Click="btnOk_OnClick" Content="Save and Launch" />
			</Grid>
		</Grid>
	</Border>
</Window>
