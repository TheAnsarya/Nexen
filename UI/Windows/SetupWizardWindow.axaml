<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Nexen"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:l="using:Nexen.Localization"
	xmlns:v="using:Nexen.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Nexen.Windows.SetupWizardWindow"
	Width="980" Height="860"
	MinWidth="860" MinHeight="720"
	WindowDecorations="None"
	CanResize="True"
	WindowStartupLocation="CenterScreen"
	x:DataType="vm:SetupWizardViewModel"
	Title="{l:Translate wndTitle}"
	Name="root"
	Background="#ff1d130d"
	Foreground="#ffffffff"
>
	<Design.DataContext>
		<vm:SetupWizardViewModel />
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="RadioButton.choiceCard">
			<Setter Property="Foreground" Value="#ffffffff" />
			<Setter Property="Background" Value="#ff2a1a10" />
			<Setter Property="BorderBrush" Value="#ffbf5e12" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="MinHeight" Value="66" />
			<Setter Property="Template">
				<ControlTemplate>
					<Grid MinHeight="{TemplateBinding MinHeight}" Cursor="Hand">
						<Path
							x:Name="CardFill"
							Data="M 8,0 L 100,0 L 100,58 L 92,66 L 0,66 L 0,8 Z"
							Stretch="Fill"
							Fill="{TemplateBinding Background}"
						/>
						<Path
							x:Name="CardStroke"
							Data="M 8,1 L 99,1 L 99,57 L 91,65 L 1,65 L 1,8 Z"
							Stretch="Fill"
							Stroke="{TemplateBinding BorderBrush}"
							StrokeThickness="2"
							Fill="Transparent"
						/>
						<ContentPresenter
							Content="{TemplateBinding Content}"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							Margin="20,10"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Center"
						/>
					</Grid>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="RadioButton.choiceCard /template/ ContentPresenter TextBlock">
			<Setter Property="Foreground" Value="#ffffffff" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ Path#CardFill">
			<Setter Property="Fill" Value="#ff4a2d1a" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ Path#CardStroke">
			<Setter Property="Stroke" Value="#ffffbd64" />
		</Style>

		<Style Selector="RadioButton.choiceCard:pointerover /template/ ContentPresenter TextBlock">
			<Setter Property="Foreground" Value="#ffffe2b8" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ Path#CardFill">
			<Setter Property="Fill" Value="#ffc46a18" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ Path#CardStroke">
			<Setter Property="Stroke" Value="#ffffd287" />
		</Style>

		<Style Selector="RadioButton.choiceCard:checked /template/ ContentPresenter TextBlock">
			<Setter Property="Foreground" Value="#ffffffff" />
		</Style>

		<Style Selector="Button.angledAction">
			<Setter Property="Foreground" Value="#ffffffff" />
			<Setter Property="Background" Value="#ffb65e18" />
			<Setter Property="BorderBrush" Value="#ffffce87" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="Padding" Value="24,12" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="FontSize" Value="20" />
			<Setter Property="MinHeight" Value="54" />
			<Setter Property="Template">
				<ControlTemplate>
					<Grid MinHeight="{TemplateBinding MinHeight}" Cursor="Hand">
						<Path
							x:Name="ActionFill"
							Data="M 8,0 L 100,0 L 100,46 L 92,54 L 0,54 L 0,8 Z"
							Stretch="Fill"
							Fill="{TemplateBinding Background}"
						/>
						<Path
							x:Name="ActionStroke"
							Data="M 8,1 L 99,1 L 99,45 L 91,53 L 1,53 L 1,8 Z"
							Stretch="Fill"
							Stroke="{TemplateBinding BorderBrush}"
							StrokeThickness="2"
							Fill="Transparent"
						/>
						<ContentPresenter
							Content="{TemplateBinding Content}"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
						/>
					</Grid>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="Button.angledAction:pointerover /template/ Path#ActionFill">
			<Setter Property="Fill" Value="#ffc87423" />
		</Style>

		<Style Selector="Button.angledAction:pointerover /template/ Path#ActionStroke">
			<Setter Property="Stroke" Value="#ffffdfa8" />
		</Style>

		<Style Selector="Button.angledAction.secondaryAction">
			<Setter Property="FontSize" Value="16" />
			<Setter Property="Padding" Value="18,8" />
			<Setter Property="MinHeight" Value="42" />
		</Style>

		<Style Selector="Button.angledAction.primaryAction">
			<Setter Property="FontSize" Value="26" />
			<Setter Property="Padding" Value="38,18" />
			<Setter Property="MinHeight" Value="72" />
			<Setter Property="Background" Value="#ffd47a22" />
			<Setter Property="BorderBrush" Value="#ffffe1aa" />
		</Style>

	</Window.Styles>

	<Border BorderThickness="2" BorderBrush="#ff6b3f24" Background="#ff1d130d">
		<Grid Margin="22" RowDefinitions="Auto,*,Auto">
			<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
				<StackPanel Spacing="4">
					<TextBlock Text="Nexen" FontSize="14" Foreground="#ffefcfb6" />
					<TextBlock Text="First Start Options" FontSize="34" FontWeight="Bold" />
					<TextBlock Text="Pick what you need now. You can change everything later." Foreground="#ffefcfb6" FontSize="16" />
				</StackPanel>
				<Image
					Grid.Column="1"
					Source="/Assets/NexenIcon.ico"
					Height="52"
					Width="52"
					VerticalAlignment="Top"
				/>
				<Border Grid.Row="1" Grid.ColumnSpan="2" IsVisible="{Binding HasResumedDraft}" Background="#ff3b2416" BorderBrush="#ffbf5e12" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,14,0,0">
					<DockPanel LastChildFill="False">
						<TextBlock DockPanel.Dock="Left" Width="700" Text="Saved setup found. Continue or start over." TextWrapping="Wrap" Foreground="#ffffffff" FontSize="16" />
						<Button DockPanel.Dock="Right" Classes="angledAction secondaryAction" Click="StartFresh_OnClick" Content="Start Fresh" />
					</DockPanel>
				</Border>
			</Grid>

			<ScrollViewer Grid.Row="1" Margin="0,16,0,16" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<Border Background="#ff2a1a10" BorderBrush="#ff6b3f24" BorderThickness="1" CornerRadius="12" Padding="16">
					<StackPanel Spacing="12">
						<TextBlock FontSize="20" FontWeight="SemiBold" Text="How will you use Nexen?" />
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="PrimaryUsage" IsChecked="{Binding UsePlayingProfile}">
								<StackPanel Spacing="4">
									<TextBlock Text="Play Games" FontSize="20" FontWeight="SemiBold" Foreground="#ffffffff" />
									<TextBlock Text="Good defaults for normal play." FontSize="16" Foreground="#ffefcfb6" />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="PrimaryUsage" IsChecked="{Binding UseDebuggingProfile}" Grid.Column="1">
								<StackPanel Spacing="4">
									<TextBlock Text="Hacking" FontSize="20" FontWeight="SemiBold" Foreground="#ffffffff" />
									<TextBlock Text="More tools and debug defaults." FontSize="16" Foreground="#ffefcfb6" />
								</StackPanel>
							</RadioButton>
						</Grid>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<Grid ColumnDefinitions="*">
							<TextBlock FontSize="20" FontWeight="SemiBold" Text="Where should Nexen save your data?" />
						</Grid>
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="Storage" IsChecked="{Binding StoreInUserProfile}">
								<StackPanel Spacing="4">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Use Documents (Recommended)" TextWrapping="Wrap" />
									<TextBlock FontSize="16" Foreground="#ffefcfb6" Text="Best for most users." />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="Storage" IsChecked="{Binding UsePortableMode}" Grid.Column="1" IsEnabled="{Binding CanUsePortableMode}">
								<StackPanel Spacing="4">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Use Current Folder" />
									<TextBlock FontSize="16" Foreground="#ffefcfb6" Text="Keep data next to Nexen." />
								</StackPanel>
							</RadioButton>
						</Grid>
							<TextBlock IsVisible="{Binding !CanUsePortableMode}" Foreground="#ffe1852c" FontSize="16" Text="Portable mode is unavailable in AppImage environments." />
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Selected path:" Foreground="#ffefcfb6" FontSize="19" FontWeight="SemiBold" />
							<TextBlock Text="{Binding InstallLocation}" FontSize="19" FontWeight="SemiBold" Foreground="#ffffffff" />
						</StackPanel>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<TextBlock FontSize="20" FontWeight="SemiBold" Text="Configure input" />
						<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
							<RadioButton Classes="choiceCard" GroupName="InputSetup" IsChecked="{Binding ConfigureInputMappingsNow}">
								<StackPanel Spacing="4">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Configure Now" />
									<TextBlock FontSize="16" Foreground="#ffefcfb6" Text="Pick prompt and keyboard style." />
								</StackPanel>
							</RadioButton>
							<RadioButton Classes="choiceCard" GroupName="InputSetup" IsChecked="{Binding UseInputDefaultsNow}" Grid.Column="1">
								<StackPanel Spacing="4">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Use Defaults" />
									<TextBlock FontSize="16" Foreground="#ffefcfb6" Text="Quick start input setup." />
								</StackPanel>
							</RadioButton>
						</Grid>

						<StackPanel IsVisible="{Binding ConfigureInputMappingsNow}" Spacing="10" Margin="0,2,0,0">
							<TextBlock FontSize="18" FontWeight="SemiBold" Text="Prompt Style" />
							<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
								<RadioButton Classes="choiceCard" GroupName="ControllerStyle" IsChecked="{Binding UseXboxPromptStyle}">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Xbox" />
								</RadioButton>
								<RadioButton Classes="choiceCard" GroupName="ControllerStyle" IsChecked="{Binding UsePlayStationPromptStyle}" Grid.Column="1">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="PlayStation" />
								</RadioButton>
							</Grid>

							<TextBlock FontSize="18" FontWeight="SemiBold" Text="Keyboard" />
							<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
								<RadioButton Classes="choiceCard" GroupName="KeyboardStyle" IsChecked="{Binding EnableWasdMappings}">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="WASD" />
								</RadioButton>
								<RadioButton Classes="choiceCard" GroupName="KeyboardStyle" IsChecked="{Binding EnableArrowMappings}" Grid.Column="1">
									<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Arrow Keys" />
								</RadioButton>
							</Grid>
						</StackPanel>

						<Border Height="1" Background="#553f2b1f" Margin="0,2,0,2" />

						<Grid ColumnDefinitions="2*,*,*" ColumnSpacing="12" IsVisible="{Binding !IsOsx}">
							<TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Desktop Shortcut" />
							<RadioButton Grid.Column="1" Classes="choiceCard" GroupName="Shortcut" IsChecked="{Binding CreateShortcutYes}" MinHeight="54">
								<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Yes" />
							</RadioButton>
							<RadioButton Grid.Column="2" Classes="choiceCard" GroupName="Shortcut" IsChecked="{Binding CreateShortcutNo}" MinHeight="54">
								<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="No" />
							</RadioButton>
						</Grid>

						<Grid ColumnDefinitions="2*,*,*" ColumnSpacing="12">
							<TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Auto Update" />
							<RadioButton Grid.Column="1" Classes="choiceCard" GroupName="Updates" IsChecked="{Binding CheckForUpdatesYes}" MinHeight="54">
								<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="Yes" />
							</RadioButton>
							<RadioButton Grid.Column="2" Classes="choiceCard" GroupName="Updates" IsChecked="{Binding CheckForUpdatesNo}" MinHeight="54">
								<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#ffffffff" Text="No" />
							</RadioButton>
						</Grid>
					</StackPanel>
				</Border>
			</ScrollViewer>

			<Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
				<Button Classes="angledAction" Content="Cancel" Click="Cancel_OnClick" />
				<TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Setup takes less than a minute." Foreground="#ffefcfb6" FontSize="20" FontWeight="SemiBold" />
				<Button Grid.Column="2" Classes="angledAction primaryAction" HorizontalAlignment="Right" Click="btnOk_OnClick" Content="Save and Launch" />
			</Grid>
		</Grid>
	</Border>
</Window>
