<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Nexen"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:c="using:Nexen.Controls"
	xmlns:l="using:Nexen.Localization"
	xmlns:v="using:Nexen.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Nexen.Windows.SetupWizardWindow"
	Width="520" Height="620"
	MinWidth="460" MinHeight="560"
	WindowDecorations="None"
	CanResize="True"
	WindowStartupLocation="CenterScreen"
	x:DataType="vm:SetupWizardViewModel"
	Title="{l:Translate wndTitle}"
	Name="root"
>
	<Design.DataContext>
		<vm:SetupWizardViewModel />
	</Design.DataContext>

	<Border BorderThickness="3" BorderBrush="Gray">
		<DockPanel Margin="10">
			<DockPanel DockPanel.Dock="Top">
				<Image
					DockPanel.Dock="Right"
					Source="/Assets/NexenIcon.ico"
					Height="32"
					Width="32"
				/>
				<StackPanel>
					<TextBlock Text="{l:Translate lblNexen}" FontSize="12" />
					<TextBlock Text="{l:Translate lblConfigWizard}" FontSize="18" />
				</StackPanel>
			</DockPanel>

			<DockPanel DockPanel.Dock="Bottom">
				<TextBlock
					Foreground="CornflowerBlue"
					Text="{l:Translate lblCancel}"
					Cursor="Hand"
					DockPanel.Dock="Left"
					VerticalAlignment="Center"
					Tapped="lblCancel_Tapped"
				/>
				<Button
					MinWidth="70"
					HorizontalAlignment="Right"
					HorizontalContentAlignment="Center"
					Click="btnOk_OnClick"
					Content="{l:Translate btnOk}"
				/>
			</DockPanel>

			<ScrollViewer AllowAutoHide="False" HorizontalScrollBarVisibility="Auto" Padding="0 0 2 0" Margin="0 30 0 0">
				<StackPanel>
					<TextBlock Text="{l:Translate lblInitialSetup}" />
					<Border IsVisible="{Binding HasResumedDraft}" Background="#22b7d3ff" BorderBrush="#66b7d3ff" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0 10 0 0">
						<StackPanel>
							<TextBlock Text="{l:Translate lblResumeDraftLoaded}" TextWrapping="Wrap" />
							<Button HorizontalAlignment="Left" Margin="0 8 0 0" Click="StartFresh_OnClick" Content="{l:Translate btnStartFresh}" />
						</StackPanel>
					</Border>

					<c:OptionSection Header="{l:Translate lblPrimaryUsage}" Margin="0 18 0 0">
						<TextBlock Text="{l:Translate lblPrimaryUsageHint}" />
						<StackPanel Margin="5 8 0 0">
							<RadioButton Content="{l:Translate radPrimaryUsagePlaying}" IsChecked="{Binding UsePlayingProfile}" />
							<TextBlock Text="{l:Translate lblPrimaryUsagePlayingHint}" Margin="24 2 0 8" TextWrapping="Wrap" Opacity="0.8" />
							<RadioButton Content="{l:Translate radPrimaryUsageDebugging}" IsChecked="{Binding UseDebuggingProfile}" />
							<TextBlock Text="{l:Translate lblPrimaryUsageDebuggingHint}" Margin="24 2 0 0" TextWrapping="Wrap" Opacity="0.8" />
						</StackPanel>
					</c:OptionSection>

					<c:OptionSection Header="{l:Translate lblStorageLocation}">
						<TextBlock Text="{l:Translate lblStorageHint}" />
						<StackPanel Margin="5 5 0 0">
							<RadioButton Content="{l:Translate radStorageDocuments}" IsChecked="{Binding StoreInUserProfile}" />
							<TextBlock Text="{l:Translate lblStorageDocumentsHint}" Margin="24 2 0 8" TextWrapping="Wrap" Opacity="0.8" />
							<RadioButton Content="{l:Translate radStoragePortable}" IsChecked="{Binding !StoreInUserProfile}" IsEnabled="{Binding CanUsePortableMode}" />
							<TextBlock Text="{l:Translate lblStoragePortableHint}" Margin="24 2 0 0" TextWrapping="Wrap" Opacity="0.8" IsEnabled="{Binding CanUsePortableMode}" />
							<TextBlock Text="{l:Translate lblStoragePortableUnavailableHint}" Margin="24 6 0 0" TextWrapping="Wrap" Opacity="0.8" Foreground="DarkOrange" IsVisible="{Binding !CanUsePortableMode}" />
						</StackPanel>
						<StackPanel Orientation="Horizontal" Margin="0 10 0 4">
							<TextBlock Text="{l:Translate lblDataLocation}" />
							<TextBlock Foreground="CornflowerBlue" Margin="5 0 0 0" Text="{Binding InstallLocation}" />
						</StackPanel>
						<Button HorizontalAlignment="Left" Click="ResetStorageToRecommended_OnClick" Content="{l:Translate btnStorageResetRecommended}" />
					</c:OptionSection>

					<c:OptionSection Header="{l:Translate lblInputMappings}">
						<TextBlock Text="{l:Translate lblInputHint}" />
						<CheckBox Content="{l:Translate chkCustomizeInputMappingsNow}" IsChecked="{Binding CustomizeInputMappingsNow}" Margin="0 8 0 0" />
						<TextBlock Text="{l:Translate lblInputDefaultsHint}" Margin="24 2 0 0" TextWrapping="Wrap" Opacity="0.8" />
						<Grid ColumnDefinitions="1*,1*,1*,1*" RowDefinitions="Auto,Auto" Margin="0 10 0 0" IsVisible="{Binding CustomizeInputMappingsNow}">
							<Image Source="/Assets/XbIcon.png" Stretch="None" Tapped="XboxIcon_Tapped" Cursor="Hand" />
							<Image Source="/Assets/PsIcon.png" Stretch="None" Grid.Column="1" Tapped="PsIcon_Tapped" Cursor="Hand" />
							<Image Source="/Assets/WasdKeys.png" Stretch="None" Grid.Column="2" Tapped="WasdIcon_Tapped" Cursor="Hand" />
							<Image Source="/Assets/ArrowKeys.png" Stretch="None" Grid.Column="3" Tapped="ArrowIcon_Tapped" Cursor="Hand" />
							<CheckBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" IsChecked="{Binding EnableXboxMappings}" />
							<CheckBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding EnablePsMappings}" />
							<CheckBox Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding EnableWasdMappings}" />
							<CheckBox Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding EnableArrowMappings}" />
						</Grid>
					</c:OptionSection>

					<c:OptionSection Header="{l:Translate lblMiscOptions}" Margin="0 25 0 0" IsVisible="{Binding !IsOsx}">
						<CheckBox Content="{l:Translate chkCreateShortcut}" IsChecked="{Binding CreateShortcut}" />
						<CheckBox Content="{l:Translate chkCheckForUpdates}" IsChecked="{Binding CheckForUpdates}" />
					</c:OptionSection>
				</StackPanel>
			</ScrollViewer>
		</DockPanel>
	</Border>
</Window>
