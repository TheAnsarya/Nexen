<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Nexen.ViewModels"
	xmlns:c="using:Nexen.Controls"
	mc:Ignorable="d" d:DesignWidth="610" d:DesignHeight="260"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
	x:Name="root"
	x:DataType="vm:KeyMappingViewModel"
	x:Class="Nexen.Views.GenesisControllerView"
>
	<Design.DataContext>
		<vm:KeyMappingViewModel />
	</Design.DataContext>

	<Border BorderBrush="{StaticResource NexenGrayBorderColor}" BorderThickness="2" Padding="3" Width="610" Height="260" HorizontalAlignment="Left" VerticalAlignment="Top">
		<Canvas>
			<Panel Canvas.Top="20">
				<Ellipse Width="200" Height="200" Stroke="{StaticResource NexenGrayBorderColor}" StrokeThickness="2" />
				<Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*" Width="200" Height="200">
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Up}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Left}" Grid.Row="1" Grid.Column="0" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Right}" Grid.Row="1" Grid.Column="1" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Down}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Width="80" Height="40" HorizontalAlignment="Center" />
				</Grid>
			</Panel>

			<Panel Canvas.Top="55" Canvas.Right="5" Width="260" Height="150">
				<Rectangle Fill="{StaticResource NexenGrayBackgroundColor}" />
				<StackPanel VerticalAlignment="Center" Spacing="8">
					<StackPanel Orientation="Horizontal">
						<c:ControllerButton
							Margin="10 0 0 0"
							Label="B"
							KeyBinding="{Binding Mapping.B}"
							TurboKeyBinding="{Binding Mapping.TurboB}"
						/>
						<c:ControllerButton
							Margin="22 0 0 0"
							Label="C"
							KeyBinding="{Binding Mapping.X}"
							TurboKeyBinding="{Binding Mapping.TurboX}"
						/>
						<c:ControllerButton
							Margin="22 0 0 0"
							Label="A"
							KeyBinding="{Binding Mapping.A}"
							TurboKeyBinding="{Binding Mapping.TurboA}"
						/>
					</StackPanel>

					<StackPanel Orientation="Horizontal">
						<c:ControllerButton
							Margin="10 0 0 0"
							Label="X"
							KeyBinding="{Binding Mapping.Y}"
							TurboKeyBinding="{Binding Mapping.TurboY}"
						/>
						<c:ControllerButton
							Margin="22 0 0 0"
							Label="Y"
							KeyBinding="{Binding Mapping.L}"
							TurboKeyBinding="{Binding Mapping.TurboL}"
						/>
						<c:ControllerButton
							Margin="22 0 0 0"
							Label="Z"
							KeyBinding="{Binding Mapping.R}"
							TurboKeyBinding="{Binding Mapping.TurboR}"
						/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Margin="10 0 0 0">
						<c:KeyBindingButton KeyBinding="{Binding Mapping.GenericKey1}" Width="90" />
						<TextBlock Text="Mode" FontSize="14" VerticalAlignment="Center" Margin="8 0 0 0" />
					</StackPanel>
				</StackPanel>
			</Panel>

			<Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto" Width="580" Canvas.Bottom="20">
				<c:KeyBindingButton KeyBinding="{Binding Mapping.Start}" Grid.Column="1" Width="90" />
				<TextBlock Grid.Column="1" Grid.Row="1" Text="Start" FontSize="14" HorizontalAlignment="Center" />
			</Grid>
		</Canvas>
	</Border>
</UserControl>
