<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:cfg="using:Nexen.Config"
	xmlns:c="using:Nexen.Controls"
	xmlns:dc="using:Nexen.Debugger.Controls"
	mc:Ignorable="d"
	Design.Width="200"
	Design.Height="600"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
	x:DataType="cfg:LynxEventViewerConfig"
	x:Class="Nexen.Debugger.Views.LynxEventViewerConfigView"
>
	<Design.DataContext>
		<cfg:LynxEventViewerConfig />
	</Design.DataContext>

	<StackPanel>
		<Grid ColumnDefinitions="10, 1*, 10, 1*" RowDefinitions="Auto,Auto">
			<c:OptionSection Header="Mikey writes" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0" />
			<c:OptionSection Header="Mikey reads" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="10 0 0 0" />
			<StackPanel Grid.Column="1" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="Mikey" Config="{Binding MikeyRegisterWrite}" />
				<dc:EventViewerCategoryControl Text="Timer" Config="{Binding TimerWrite}" />
				<dc:EventViewerCategoryControl Text="Audio" Config="{Binding AudioRegisterWrite}" />
				<dc:EventViewerCategoryControl Text="Palette" Config="{Binding PaletteWrite}" />
			</StackPanel>
			<StackPanel Grid.Column="3" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="Mikey" Config="{Binding MikeyRegisterRead}" />
				<dc:EventViewerCategoryControl Text="Timer" Config="{Binding TimerRead}" />
				<dc:EventViewerCategoryControl Text="Audio" Config="{Binding AudioRegisterRead}" />
			</StackPanel>
		</Grid>

		<Grid ColumnDefinitions="10, 1*, 10, 1*" RowDefinitions="Auto,Auto" Margin="0 15 0 0">
			<c:OptionSection Header="Suzy writes" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0" />
			<c:OptionSection Header="Suzy reads" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="10 0 0 0" />
			<StackPanel Grid.Column="1" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="Suzy" Config="{Binding SuzyRegisterWrite}" />
			</StackPanel>
			<StackPanel Grid.Column="3" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="Suzy" Config="{Binding SuzyRegisterRead}" />
			</StackPanel>
		</Grid>

		<c:OptionSection Header="Other events" />
		<StackPanel>
			<dc:EventViewerCategoryControl Text="IRQ" Config="{Binding Irq}" />
			<dc:EventViewerCategoryControl Text="Marked Breakpoints" Config="{Binding MarkedBreakpoints}" />
		</StackPanel>

		<CheckBox Margin="0 10 0 0" IsChecked="{Binding ShowPreviousFrameEvents}" Content="Show previous frame events" />
	</StackPanel>
</UserControl>
